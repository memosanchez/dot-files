{
  "env": {},
  "effortLevel": "max",
  "cleanupPeriodDays": 90,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run test)",
      "Bash(pnpm run build)",
      "Bash(pnpm run typecheck)",
      "Bash(yarn lint)",
      "Bash(yarn test)",
      "Bash(yarn build)",
      "Bash(yarn typecheck)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh run download:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git tag -l:*)",
      "Bash(git stash list:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew search:*)",
      "Bash(brew config:*)",
      "Bash(brew doctor:*)",
      "Bash(ls:*)",
      "Bash(diff:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(jq:*)",
      "Bash(python --version:*)",
      "Bash(node --version:*)",
      "Bash(npm --version:*)",
      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker logs:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:developer.mozilla.org)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- :*)",
      "Bash(git clean:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(chmod -R 777:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: Use built-in tools (Read, Grep, Glob, Edit) instead of Bash equivalents. Check CLAUDE.md for full guidelines.'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": [
    "github@claude-plugins-official",
    "linear@claude-plugins-official",
    "playwright@claude-plugins-official"
  ],
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name // \"?\"'); case \"$model\" in *Sonnet*) mc=96;; *Opus*) mc=95;; *Haiku*) mc=92;; *) mc=97;; esac; ctx=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); ctx_str=\"\"; if [ -n \"$ctx\" ]; then ctx_int=${ctx%.*}; if [ \"$ctx_int\" -ge 80 ]; then cc=31; elif [ \"$ctx_int\" -ge 60 ]; then cc=33; else cc=32; fi; ctx_str=\" \\033[${cc}m${ctx_int}%\\033[0m\"; fi; printf \"\\033[${mc}m%s\\033[0m%b\" \"$model\" \"$ctx_str\""
  }
}
